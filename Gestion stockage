<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculateur Stock & Cave</title>
    <style>
        /* STYLE CSS */
        :root {
            --bg: #0f172a;
            --card: #1e293b;
            --accent: #38bdf8;
            --danger: #f43f5e;
            --text: #f8fafc;
        }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            display: flex;
            justify-content: center;
            padding: 20px;
            margin: 0;
        }

        .container {
            width: 100%;
            max-width: 800px;
        }

        h1 { text-align: center; color: var(--accent); margin-bottom: 30px; }

        .dashboard {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 30px;
        }

        .card {
            background: var(--card);
            padding: 20px;
            border-radius: 12px;
            text-align: center;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            border: 1px solid #334155;
        }

        .card h3 { margin: 0 0 10px 0; font-size: 0.9rem; color: #94a3b8; text-transform: uppercase; }
        .card p { margin: 0; font-size: 1.5rem; font-weight: bold; }
        .highlight { border-color: var(--accent); color: var(--accent); }

        .inputs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            background: var(--card);
            padding: 15px;
            border-radius: 12px;
        }

        input {
            padding: 12px;
            border-radius: 6px;
            border: 1px solid #334155;
            background: #0f172a;
            color: white;
            flex: 1;
        }

        button {
            padding: 12px 20px;
            background: var(--accent);
            color: #0f172a;
            border: none;
            border-radius: 6px;
            font-weight: bold;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        button:hover { opacity: 0.8; }

        table {
            width: 100%;
            border-collapse: collapse;
            background: var(--card);
            border-radius: 12px;
            overflow: hidden;
        }

        th { background: #334155; padding: 15px; text-align: left; font-size: 0.8rem; }
        td { padding: 15px; border-bottom: 1px solid #334155; }

        .btn-delete {
            background: var(--danger);
            color: white;
            padding: 6px 12px;
            font-size: 0.75rem;
        }

        .empty-msg { text-align: center; padding: 20px; color: #64748b; }
    </style>
</head>
<body>

<div class="container">
    <h1>📦 Ma Cave Business</h1>

    <div class="dashboard">
        <div class="card">
            <h3>Loyer Cave / mois</h3>
            <input type="number" id="caveCost" value="50" style="width: 80%; text-align: center;" oninput="calculate()">
        </div>
        <div class="card">
            <h3>Articles en Stock</h3>
            <p id="totalCount">0</p>
        </div>
        <div class="card highlight">
            <h3>Frais Stockage / Unité</h3>
            <p id="unitStorage">0.00 €</p>
        </div>
    </div>

    <div class="inputs">
        <input type="text" id="name" placeholder="Nom du produit">
        <input type="number" id="buyPrice" placeholder="Prix d'achat (€)">
        <button onclick="addItem()">Ajouter</button>
    </div>

    <table>
        <thead>
            <tr>
                <th>PRODUIT</th>
                <th>ACHAT</th>
                <th>FRAIS CAVE</th>
                <th>TOTAL REVIENT</th>
                <th>ACTION</th>
            </tr>
        </thead>
        <tbody id="inventoryList">
            </tbody>
    </table>
    <div id="empty" class="empty-msg">Aucun produit en stock actuellement.</div>
</div>

<script>
    /* LOGIQUE JAVASCRIPT */
    let stock = JSON.parse(localStorage.getItem('monStock')) || [];

    function addItem() {
        const name = document.getElementById('name');
        const price = document.getElementById('buyPrice');

        if (name.value === "" || price.value === "") return;

        const newItem = {
            id: Date.now(),
            name: name.value,
            buyPrice: parseFloat(price.value)
        };

        stock.push(newItem);
        saveAndRefresh();
        
        name.value = "";
        price.value = "";
    }

    function deleteItem(id) {
        stock = stock.filter(item => item.id !== id);
        saveAndRefresh();
    }

    function saveAndRefresh() {
        localStorage.setItem('monStock', JSON.stringify(stock));
        calculate();
    }

    function calculate() {
        const caveTotal = parseFloat(document.getElementById('caveCost').value) || 0;
        const count = stock.length;
        
        // Formule : Loyer / Nombre d'objets
        const costPerUnit = count > 0 ? (caveTotal / count) : 0;

        document.getElementById('totalCount').innerText = count;
        document.getElementById('unitStorage').innerText = costPerUnit.toFixed(2) + " €";

        render(costPerUnit);
    }

    function render(unitCost) {
        const list = document.getElementById('inventoryList');
        const emptyMsg = document.getElementById('empty');
        
        list.innerHTML = "";
        
        if (stock.length === 0) {
            emptyMsg.style.display = "block";
        } else {
            emptyMsg.style.display = "none";
            stock.forEach(item => {
                const totalRevient = item.buyPrice + unitCost;
                list.innerHTML += `
                    <tr>
                        <td><strong>${item.name}</strong></td>
                        <td>${item.buyPrice.toFixed(2)} €</td>
                        <td>${unitCost.toFixed(2)} €</td>
                        <td style="color: var(--accent)">${totalRevient.toFixed(2)} €</td>
                        <td><button class="btn-delete" onclick="deleteItem(${item.id})">Vendu</button></td>
                    </tr>
                `;
            });
        }
    }

    // Lancer au chargement
    calculate();
</script>

</body>
</html>
